# Cloned upstream repo — kept locally for reference/consultation only, NOT part of this project
weakauras2/

# Node
node_modules/
npm-debug.log*

# Dev launcher log (scripts/dev.mjs tees `npm run dev` output here, truncated each run)
dev.log

# Secrets — never commit real keys (keep .env.example)
.env
!.env.example

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp

# Generated WeakAuras artifacts — derived from *.import.txt / build.js, not versioned.
# We keep dist/<class>.import.txt (the deliverable) but not these derived/churn files.
weakauras/dist/*.decoded.json
weakauras/dist/*.prev.import.txt
