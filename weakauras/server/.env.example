# Copy to .env and fill in. Loaded via `node --env-file=.env server.mjs`.

# OpenRouter API key (required) — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: model cascade, cheapest/free first (comma-separated). Falls back to the built-in default.
# AGENT_MODELS=meta-llama/llama-3.3-70b-instruct:free,openai/gpt-oss-20b:free,openai/gpt-4o-mini

# Optional: HTTP port for server.mjs (default 8374).
# PORT=8374
